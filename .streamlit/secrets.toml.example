# Google Sheets + Apps Script Configuration
# =============================================
# 
# Follow these steps to set up Google Sheets backend:
# 1. Create a new Google Sheet
# 2. Deploy the provided Google Apps Script
# 3. Copy the deployment URL to GOOGLE_APPS_SCRIPT_URL
# 4. Rename this file to secrets.toml and update the URLs

# Required: Google Apps Script deployment URL (POST endpoint for saving annotations)
# This is the URL you get after deploying the Google Apps Script
GOOGLE_APPS_SCRIPT_URL = "https://script.google.com/macros/d/{DEPLOYMENT_ID}/usercurrent/do?userAccessType=ANYONE"

# Required: Google Sheet read URL (GET endpoint for fetching saved progress)
# This can be the same as GOOGLE_APPS_SCRIPT_URL or a separate read-only endpoint
GOOGLE_SHEET_READ_URL = "https://script.google.com/macros/d/{DEPLOYMENT_ID}/usercurrent/do?userAccessType=ANYONE"

# Optional: Nextcloud share URL for remote cluster data (if not using local files)
# sharecloudlink = "https://your-nextcloud.com/ocs/v2.php/apps/files_sharing/api/v1/shares/..."
